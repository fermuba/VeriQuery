# ========================================
# VeriQuery - Environment Variables
# ========================================

# AZURE KEY VAULT CONFIGURATION (NEW!)
# ========================================

# Required: Your Azure Key Vault URL
# Format: https://{vault-name}.vault.azure.net/
# Get from: Azure Portal > Your Key Vault > Overview > Vault URI
KEYVAULT_URL=https://your-vault-name.vault.azure.net/

# Optional: Service Principal Authentication
# If not set, DefaultAzureCredential will be used (recommended for development)
AZURE_KEYVAULT_SP_CLIENT_ID=
AZURE_KEYVAULT_SP_CLIENT_SECRET=
AZURE_KEYVAULT_SP_TENANT_ID=


# AZURE OPENAI CONFIGURATION
# ========================================

# Azure AI Foundry
AZURE_OPENAI_ENDPOINT=https://<your-resource>.services.ai.azure.com/
AZURE_OPENAI_API_KEY=<your-azure-openai-api-key>
AZURE_OPENAI_DEPLOYMENT_GPT4O_MINI=gpt-4o-mini-deployment
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# DATABASE CONFIGURATION
# ========================================

# Note: With Key Vault integration, database credentials are stored securely
# and NOT in environment variables. Use the API endpoints to manage them.

# Active database name (from saved configurations)
ACTIVE_DATABASE=ContosoV210k

# Database directory (for SQLite or config files)
DATABASE_DIR=./databases


# API CONFIGURATION
# ========================================

API_HOST=0.0.0.0
API_PORT=8888
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173
API_TIMEOUT=30


# LOGGING
# ========================================

LOG_LEVEL=INFO
LOG_FILE=./logs/backend.log
ERROR_LOG_FILE=./logs/backend_err.log
DEBUG_SQL=false


# SECURITY
# ========================================

JWT_SECRET=your-super-secret-key-change-this
JWT_EXPIRATION_HOURS=24
HTTPS_ONLY=false


# DEVELOPMENT
# ========================================

DEBUG=false
RELOAD=true
INCLUDE_TEST_ENDPOINTS=false


# NOTES:
# 1. NEVER commit this file with real secrets
# 2. Use .env.local for sensitive values (add to .gitignore)
# 3. See docs/AZURE_KEYVAULT_INTEGRATION.md for setup
# 4. For local auth: az login && az account set --subscription <id>
